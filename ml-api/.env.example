# --- Core ---
# ML API server port
PORT=8000

# Comma-separated allowed frontend origins for CORS
# Example: FRONTEND_ORIGINS=https://gigcover.vercel.app,https://www.gigcover.app
FRONTEND_ORIGINS=http://localhost:3000

# --- Supabase (required for live ingestion) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- OpenWeather (required for live ingestion) ---
OPENWEATHER_API_KEY=your-openweather-api-key
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5
OPENWEATHER_UNITS=metric

# --- Ingestion controls ---
WEATHER_SYNC_ENABLED=true
WEATHER_SYNC_INTERVAL_SEC=300
WEATHER_HTTP_TIMEOUT_SECONDS=10
WEATHER_SOURCE_NAME=openweathermap
WEATHER_ENABLE_TRIGGER_EVENT_WRITES=true
